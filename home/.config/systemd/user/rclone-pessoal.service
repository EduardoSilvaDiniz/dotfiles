[Unit]
Description=Pessoal (rclone)
AssertPathIsDirectory=/home/edu/.local/rclone/pessoal
# Make sure we have network enabled
After=network.target

[Service]
Type=simple

ExecStart=/usr/bin/rclone mount --vfs-cache-mode full pessoal: /home/edu/.local/rclone/pessoal

# Perform lazy unmount
ExecStop=/usr/bin/fusermount -zu %h/.local/rclone/pessoal

# Restart the service whenever rclone exists with non-zero exit code
Restart=on-failure
RestartSec=15

[Install]
# Autostart after reboot
WantedBy=default.target
